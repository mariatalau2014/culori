<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Calcule 2 Cifre</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
      color: #fff;
    }
    .container {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 30px;
      max-width: 500px;
      width: 100%;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }
    h1 {
      margin-bottom: 15px;
      font-size: 1.8rem;
    }
    .info {
      background: rgba(255, 255, 255, 0.15);
      padding: 12px;
      border-radius: 12px;
      margin: 15px 0;
      font-size: 0.95rem;
    }
    .progress {
      display: flex;
      justify-content: space-between;
      margin: 15px 0;
      font-weight: bold;
    }
    .problem {
      font-size: 2.2rem;
      margin: 25px 0;
      font-weight: bold;
      background: rgba(255, 255, 255, 0.2);
      padding: 20px;
      border-radius: 15px;
      letter-spacing: 2px;
    }
    input[type="number"] {
      width: 100%;
      padding: 15px;
      font-size: 1.5rem;
      text-align: center;
      border: 3px solid #a78bfa;
      border-radius: 12px;
      background: #fff;
      color: #333;
      margin: 15px 0;
      outline: none;
      transition: border-color 0.3s;
    }
    input[type="number"]:focus {
      border-color: #fff;
    }
    .btn {
      background: #fff;
      color: #6d28d9;
      border: none;
      padding: 14px 30px;
      font-size: 1.1rem;
      font-weight: bold;
      border-radius: 50px;
      cursor: pointer;
      margin: 10px 5px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.3);
    }
    .btn:active {
      transform: translateY(0);
    }
    .btn-exit {
      background: #f87171;
      color: white;
    }
    .message {
      margin-top: 20px;
      min-height: 24px;
      font-weight: 500;
      padding: 10px;
      border-radius: 10px;
    }
    .success {
      background: rgba(34, 197, 94, 0.3);
      color: #fff;
    }
    .error {
      background: rgba(248, 113, 113, 0.3);
      color: #fff;
    }
    .hidden {
      display: none;
    }
    .score-display {
      font-size: 1.3rem;
      margin: 10px 0;
      font-weight: bold;
    }
    .restart-hint {
      font-size: 0.9rem;
      opacity: 0.9;
      margin-top: 10px;
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🔢 Calcule cu 2 Cifre</h1>
    
    <div id="startScreen">
      <p class="info">
        ✅ 20 de probleme<br>
        ➕➖ Adunări și scăderi<br>
        ❌ Dacă greșești UNA → o iei de la capăt!<br>
        🎯 Scor maxim: 100 puncte
      </p>
      <button class="btn" onclick="startGame()">▶️ Începe Jocul</button>
      <button class="btn btn-exit" onclick="exitApp()">🚪 Ieșire</button>
    </div>

    <div id="gameScreen" class="hidden">
      <div class="progress">
        <span>Problema: <span id="currentNum">1</span>/20</span>
        <span class="score-display">Scor: <span id="score">100</span></span>
      </div>
      
      <div class="problem" id="problemText">45 + 23 = ?</div>
      
      <input type="number" id="answerInput" placeholder="Răspunsul tău" autocomplete="off" />
      
      <div>
        <button class="btn" onclick="checkAnswer()">✅ Verifică</button>
        <button class="btn btn-exit" onclick="exitApp()">🚪 Ieșire</button>
      </div>
      
      <div id="message" class="message hidden"></div>
      <p class="restart-hint">⚠️ Un răspuns greșit = restart total!</p>
    </div>

    <div id="endScreen" class="hidden">
      <h2>🎉 Felicitări!</h2>
      <p class="info">
        Ai rezolvat toate cele 20 de probleme!<br>
        Scor final: <strong id="finalScore">100</strong> / 100
      </p>
      <button class="btn" onclick="startGame()">🔄 Joacă din nou</button>
      <button class="btn btn-exit" onclick="exitApp()">🚪 Ieșire</button>
    </div>
  </div>

  <script>
    let currentProblem = 1;
    let score = 100;
    let problems = [];
    const TOTAL_PROBLEMS = 20;

    function generateProblems() {
      problems = [];
      for (let i = 0; i < TOTAL_PROBLEMS; i++) {
        const a = Math.floor(Math.random() * 90) + 10; // 10-99
        const b = Math.floor(Math.random() * 90) + 10;
        const op = Math.random() > 0.5 ? '+' : '-';
        
        let correctAnswer;
        if (op === '+') {
          correctAnswer = a + b;
        } else {
          // Ensure non-negative result for subtraction
          const [max, min] = a >= b ? [a, b] : [b, a];
          correctAnswer = max - min;
          problems.push({ 
            text: `${max} - ${min} = ?`, 
            answer: correctAnswer,
            a: max,
            b: min,
            op: '-'
          });
          continue;
        }
        
        problems.push({ 
          text: `${a} ${op} ${b} = ?`, 
          answer: correctAnswer,
          a, b, op
        });
      }
    }

    function showScreen(id) {
      ['startScreen', 'gameScreen', 'endScreen'].forEach(sid => {
        document.getElementById(sid).classList.add('hidden');
      });
      document.getElementById(id).classList.remove('hidden');
    }

    function startGame() {
      currentProblem = 1;
      score = 100;
      generateProblems();
      updateUI();
      showScreen('gameScreen');
      document.getElementById('answerInput').value = '';
      document.getElementById('answerInput').focus();
      hideMessage();
    }

    function updateUI() {
      document.getElementById('currentNum').textContent = currentProblem;
      document.getElementById('score').textContent = score;
      document.getElementById('problemText').textContent = problems[currentProblem - 1].text;
      document.getElementById('answerInput').value = '';
      document.getElementById('answerInput').focus();
    }

    function showMessage(text, type) {
      const msg = document.getElementById('message');
      msg.textContent = text;
      msg.className = `message ${type}`;
      msg.classList.remove('hidden');
    }

    function hideMessage() {
      document.getElementById('message').classList.add('hidden');
    }

    function checkAnswer() {
      const input = document.getElementById('answerInput');
      const userAnswer = parseInt(input.value);
      const problem = problems[currentProblem - 1];
      
      if (isNaN(userAnswer)) {
        showMessage('⚠️ Te rog scrie un număr!', 'error');
        return;
      }
      
      if (userAnswer === problem.answer) {
        // Răspuns corect
        if (currentProblem === TOTAL_PROBLEMS) {
          // Finalizat!
          document.getElementById('finalScore').textContent = score;
          showScreen('endScreen');
        } else {
          currentProblem++;
          updateUI();
          showMessage('✅ Corect! Continuă...', 'success');
          setTimeout(hideMessage, 800);
        }
      } else {
        // Răspuns greșit → RESTART
        score = Math.max(0, score - 5); // Deduct 5 points as per preference
        showMessage(`❌ Greșit! Răspunsul corect: ${problem.answer}.<br>🔄 O luăm de la capăt!`, 'error');
        setTimeout(() => {
          startGame(); // Restart from beginning
        }, 2000);
      }
    }

    function exitApp() {
      if (confirm('Ești sigur că vrei să ieși? Progresul se va pierde.')) {
        alert('👋 La revedere! Mulțumim că ai jucat!');
        // In a real app, you could close window or redirect
        location.reload();
      }
    }

    // Allow Enter key to submit answer
    document.getElementById('answerInput')?.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        checkAnswer();
      }
    });

    // Initialize
    document.getElementById('answerInput')?.focus();
  </script>
</body>
</html>